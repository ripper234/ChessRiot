# Database used by Prisma/NextAuth. Use a ChessRiot-owned Postgres database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chessriot?schema=public"

# NextAuth application URL and secret.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-secret"

# Google OAuth client configured for ChessRiot callback URLs.
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
