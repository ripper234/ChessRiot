# ChessRiot local environment template
# Copy this file to .env.local for local development.
# Do not commit real secrets or production credentials.

# App
APP_NAME=ChessRiot
APP_ENV=development
APP_URL=http://localhost:3000

# Supabase / database
# TODO: Replace with the selected ChessRiot Supabase project values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Authentication
# Google login is required for the MVP.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Notifications
# MVP can start with in-app notifications and email; web push can be enabled later.
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Feature flags
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEB_PUSH_NOTIFICATIONS=false
ENABLE_AI_COACH=false
ENABLE_CHAOS_MODE=false
