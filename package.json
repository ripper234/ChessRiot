{
  "name": "chessriot",
  "version": "0.3.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "bash scripts/sites-env.sh -- tsc --noEmit",
    "test": "bash scripts/sites-env.sh -- vitest run",
    "test:e2e": "bash scripts/sites-env.sh -- node tests/e2e-local.mjs",
    "test:render": "npm run build && node --test tests/rendered-html.test.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate",
    "release:patch": "node scripts/release-version.mjs patch",
    "release:minor": "node scripts/release-version.mjs minor",
    "release:major": "node scripts/release-version.mjs major",
    "release:check": "node scripts/release-version.mjs check"
  },
  "dependencies": {
    "chess.js": "1.4.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "4.20260702.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "3.2.4",
    "wrangler": "4.92.0"
  }
}
